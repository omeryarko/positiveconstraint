# positiveconstraint.com — static site on Namecheap cPanel (Apache/LiteSpeed)

DirectoryIndex index.html

# Force HTTPS + canonical host (no www)
RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://positiveconstraint.com%{REQUEST_URI} [L,R=301]

# Legacy paths -> canonical /ideas/* tree
RewriteRule ^about/?$ /ideas/about/ [R=301,L]
RewriteRule ^services/?$ /ideas/services/ [R=301,L]
RewriteRule ^faq/?$ /ideas/faq/ [R=301,L]
RewriteRule ^contact/?$ /ideas/contact/ [R=301,L]
RewriteRule ^abstraction/?$ /ideas/abstraction/ [R=301,L]
RewriteRule ^process/?$ /ideas/process/ [R=301,L]
RewriteRule ^core-constraints/?$ /ideas/core-constraints/ [R=301,L]
RewriteRule ^positive-constraint/?$ /ideas/positive-constraint/ [R=301,L]
RewriteRule ^work/tapouts/?$ /ideas/work-tapouts/ [R=301,L]
RewriteRule ^work/leap-commerce/?$ /ideas/work-leap-commerce/ [R=301,L]
RewriteRule ^work/user1st/?$ /ideas/work-user1st/ [R=301,L]
RewriteRule ^work/cortisense/?$ /ideas/work-cortisense/ [R=301,L]
RewriteRule ^work/?$ /ideas/work/ [R=301,L]

# Pretty URLs: /foo -> /foo/ so DirectoryIndex serves index.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.+)$ /$1/ [L,R=301]

ErrorDocument 404 /index.html

# Caching: HTML short, assets long
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>
